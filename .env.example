NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

DATABASE_URL=mongodb+srv://USERNAME:PASSWORD@CLUSTER/coursehub

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Optional seed credentials (set both email and password for each account)
# DEMO_USER_EMAIL=demo@example.com
# DEMO_USER_PASSWORD=replace-with-a-demo-password
# DEMO_ADMIN_EMAIL=admin@example.com
# DEMO_ADMIN_PASSWORD=replace-with-an-admin-password
